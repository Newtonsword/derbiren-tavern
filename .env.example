# Derbiren Tavern .env
# =============
# 复制此文件为 .env 并填入你的 API key

# LLM 端点（必填）
# 支持 DeepSeek / OpenAI / 任何兼容 API
# 免费获取 DeepSeek key: https://platform.deepseek.com/api_keys
OPENAI_API_KEY=*** use a placeholder
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 可选：便宜模型（用于简单交互如 /day 锻炼、状态查询等）
# 留空则所有请求使用 LLM_MODEL
# LLM_CHEAP_MODEL=deepseek-chat

# 可选参数
# LLM_TEMPERATURE=0.85
# LLM_MAX_TOKENS=*** WEB_PORT=8099
# SSL_VERIFY=true  (Windows默认false，Linux/Mac默认true)
